#!/bin/bash
#
# Edit file in terminal vim, and return to phpstorm

/Applications/Ghostty.app/Contents/MacOS/ghostty --command="nvim ${1:+$1}" --quit-after-last-window-closed

# Send Escape to PhpStorm to dismiss the command output prompt
osascript -e 'delay 0.25' -e 'tell application "System Events" to tell process "PhpStorm" to key code 53' &
